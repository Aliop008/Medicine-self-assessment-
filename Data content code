  chR: svgPath('<path d="m9 18 6-6-6-6"/>','14'),
  arL: svgPath('<path d="m12 19-7-7 7-7"/><path d="M19 12H5"/>','14'),
  arR: svgPath('<path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>','14'),
  rot: svgPath('<path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/>','14'),
  bulb: svgPath('<path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"/><path d="M9 18h6"/><path d="M10 22h4"/>','14'),
