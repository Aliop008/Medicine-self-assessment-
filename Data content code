function render(){
  const app = document.getElementById('app');
  let html = '<div class="app">' + renderSidebar();
  html += '<div class="main">';
  if (S.view === 'home') html += renderHome();
  else if (isDone()) html += renderResults();
  else html += renderQuiz();
  html += '</div></div>';
  app.innerHTML = html;
  attachEvents();
}

function renderSidebar(){
  const col = S.sbCol;
  let nav = '';
  if (!col) {
    nav += '<button class="sb-home' + (!S.tid?' act':'') + '" data-action="home">' + ICO.home + ' Dashboard</button>';
    for (const g of GROUPS) {
      const open = S.exGrps[g.label] !== false;
      nav += '<div>';
      nav += '<button class="sb-grp-btn' + (open?' open':'') + '" data-group="' + g.label + '">';
      nav += '<span>' + g.label + '</span>';
      nav += '<span class="arr">' + ICO.chR + '</span>';
      nav += '</button>';
      nav += '<div class="sb-items' + (open?' open':'') + '">';
      for (const id of g.ids) {
        const t = tmap[id]; if (!t) continue;
        const sc = S.scores[id];
        const act = S.tid === id;
        nav += '<button class="sb-topic' + (act?' act':'') + '" data-topic="' + id + '">';
        nav += '<span class="sb-tn">' + t.t + '</span>';
        if (sc && sc.done) nav += '<span class="sb-dot"></span>';
        else if (sc) nav += '<span class="sb-tp">' + sc.correct + '/' + t.qs.length + '</span>';
        nav += '</button>';
      }
      nav += '</div></div>';
    }
  } else {
    nav += '<div class="sb-col-nav">';
    nav += '<button class="sb-icon' + (!S.tid?' act':'') + '" data-action="home" title="Dashboard">' + ICO.home + '</button>';
    nav += '</div>';
  }

  let out = '<aside class="sb' + (col?' col':'') + '">';
  out += '<div class="sb-head">';
  if (!col) {
    out += '<div class="sb-brand" data-action="home">';
    out += svgPath('<path d="M4.8 2.3A.3.3 0 1 0 5 2H4a2 2 0 0 0-2 2v5a6 6 0 0 0 6 6 6 6 0 0 0 6-6V4a2 2 0 0 0-2-2h-1a.2.2 0 1 0 .3.3"/><path d="M8 15v1a6 6 0 0 0 6 6 6 6 0 0 0 6-6v-4"/><circle cx="20" cy="10" r="2"/>','22');
    out += '<div><div class="sb-brand-t">Davidson\'s</div><div class="sb-brand-s">Self-Assessment</div></div>';
    out += '</div>';
  }
  out += '<button class="sb-toggle" data-action="toggleSB">' + (col ? ICO.chR : ICO.chL) + '</button>';
  out += '</div>';
  out += '<nav class="sb-nav">' + nav + '</nav>';
  out += '</aside>';
  return out;
}

function renderHome(){
  const completed = Object.values(S.scores).filter(s=>s.done).length;
  const totalC = Object.values(S.scores).reduce((s,x)=>s+x.correct,0);
  const totalA = Object.values(S.scores).reduce((s,x)=>s+x.correct+x.wrong+x.skipped,0);
  const acc = totalA > 0 ? Math.round(totalC/totalA*100) : 0;

  let out = '<div class="home">';
  out += '<div class="hero">';
  out += '<div class="hero-bg"><div class="hero-c hc1"></div><div class="hero-c hc2"></div></div>';
  out += '<div class="hc-content">';
  out += svgPath('<path d="M4.8 2.3A.3.3 0 1 0 5 2H4a2 2 0 0 0-2 2v5a6 6 0 0 0 6 6 6 6 0 0 0 6-6V4a2 2 0 0 0-2-2h-1a.2.2 0 1 0 .3.3"/><path d="M8 15v1a6 6 0 0 0 6 6 6 6 0 0 0 6-6v-4"/><circle cx="20" cy="10" r="2"/>','32');
  out += '<h1>Davidson\'s Self-Assessment</h1>';
  out += '<p>Master clinical knowledge across 23 domains &middot; AI-powered scientific hints</p>';
  out += '</div></div>';

  out += '<div class="stats">';
  out += '<div class="stat" style="color:var(--teal-dark)">' + ICO.trophy + '<span class="stat-v">' + topics.length + '</span><span class="stat-l">Topics</span></div>';
  out += '<div class="stat" style="color:var(--purple)">' + ICO.award + '<span class="stat-v">' + completed + '</span><span class="stat-l">Completed</span></div>';
  out += '<div class="stat" style="color:var(--teal)">' + ICO.trend + '<span class="stat-v">' + acc + '%</span><span class="stat-l">Accuracy</span></div>';
  out += '<div class="stat" style="color:var(--red)">' + ICO.chk + '<span class="stat-v">' + totalC + '</span><span class="stat-l">Correct</span></div>';
  out += '</div>';

  out += '<div class="grps">';
  for (const g of GROUPS) {
    out += '<div class="grp-card">';
    out += '<div class="grp-hdr" style="border-left-color:' + g.color + '">' + g.label + '</div>';
    out += '<div class="t-grid">';
    for (const id of g.ids) {
      const t = tmap[id]; if (!t) continue;
      const sc = S.scores[id];
      const done = sc && sc.done;
      const prog = sc ? Math.round((sc.correct+sc.wrong+sc.skipped)/t.qs.length*100) : 0;
      out += '<button class="t-card' + (done?' done':'') + '" data-topic="' + id + '">';
      out += '<div class="t-hdr"><span class="t-title">' + t.t + '</span>';
      if (done) out += '<span style="color:#D97706;font-size:13px">&#9733;</span>';
      out += '</div>';
      out += '<div class="t-meta"><span>' + t.qs.length + ' questions</span>';
      if (sc) out += '<span class="t-score">' + sc.correct + '/' + t.qs.length + '</span>';
      out += '</div>';
      out += '<div class="t-bar"><div class="t-fill" style="width:' + prog + '%;background:' + (done?'#1D9E75':'#534AB7') + '"></div></div>';
      out += '</button>';
    }
    out += '</div></div>';
  }
  out += '</div></div>';
  return out;
}

function renderQuiz(){
  const t = ct(), q = cq();
  if (!t||!q) return '';
  const prog = S.answered.size/total()*100;

  let out = '<div class="qz">';

  // Header
  out += '<div class="qz-hdr"><div class="qz-hdr-inner">';
  out += '<button class="qz-btn" data-action="home">' + ICO.arL + '</button>';
  out += '<div style="flex:1"><div class="qz-title">' + t.t + '</div><div class="qz-sub">Question ' + (S.qi+1) + ' of ' + total() + '</div></div>';
  out += '<button class="qz-btn" data-action="reset" title="Restart">' + ICO.rot + '</button>';
  out += '</div></div>';

  // Score chips
  out += '<div class="score-bar">';
  out += '<div class="chip chip-ok">' + ICO.chk + ' Correct <span class="chip-v">' + S.correct + '</span></div>';
  out += '<div class="chip chip-ng">' + ICO.xc + ' Wrong <span class="chip-v">' + S.wrong + '</span></div>';
  out += '<div class="chip chip-rm">' + ICO.help + ' Remaining <span class="chip-v">' + remaining() + '</span></div>';
  out += '</div>';

  // Progress bar
  out += '<div class="prog"><div class="prog-f" style="width:' + prog + '%"></div></div>';

  // Navigator
  out += '<div class="q-nav">';
  for (let i = 0; i < total(); i++) {
    let cls = 'nd';
    if (i===S.qi) cls+=' act';
    else if (S.wrongSet.has(i)) cls+=' wrg';
    else if (S.answered.has(i)) cls+=' ans';
    out += '<button class="' + cls + '" data-goto="' + i + '">' + (i+1) + '</button>';
  }
  out += '</div>';

  // Question card
  out += '<div class="q-card">';
  out += '<p class="q-text">' + q.q + '</p>';
  out += '<div class="opts">';
  for (let i = 0; i < q.ok.length; i++) {
    const k=q.ok[i], v=q.ov[i];
    let rowCls='opt', badgeCls='ob ob-d';
    if (!S.submitted) {
      if (S.sel===k){rowCls+=' sel';badgeCls='ob ob-s';}
    } else {
      if (k===q.a){rowCls+=' ok';badgeCls='ob ob-ok';}
      else if (S.sel===k){rowCls+=' ng';badgeCls='ob ob-ng';}
    }
    out += '<button class="' + rowCls + '" data-answer="' + k + '"' + (S.submitted?' disabled':'') + '>';
    out += '<span class="' + badgeCls + '">' + k + '</span>';
    out += '<span class="ot">' + v + '</span>';
    out += '</button>';
  }
  out += '</div>';

  // Hint
  if (S.showHint && !S.submitted) {
    out += '<div class="hint-box">';
    out += '<div class="hint-ico">&#128161;</div>';
    if (S.hintLoading) {
      out += '<div style="font-style:italic;font-size:13px;color:var(--amber);display:flex;align-items:center;gap:8px">Generating scientific hint… <span class="dots"><span></span><span></span><span></span></span></div>';
    } else {
      out += '<p class="hint-txt">' + (S.hintText||'') + '</p>';
    }
    out += '</div>';
  }

  // Explanation
  if (S.submitted) {
    const isOk = S.sel===q.a;
    out += '<div class="exp ' + (isOk?'ok':'ng') + '">';
    out += '<div class="exp-hdr">';
    out += '<span class="exp-ico ' + (isOk?'ok':'ng') + '">' + (isOk?'&#10003;':'&#10007;') + '</span>';
    out += '<span class="exp-title">' + (isOk?'Correct!':'Incorrect') + '</span>';
    if (!isOk) out += '<span class="exp-clbl">Correct: ' + q.a + '</span>';
    out += '</div>';
    out += '<p class="exp-txt">' + (q.e||"See Davidson's for full explanation.") + '</p>';
    out += '</div>';
  }

  // Action buttons
  out += '<div class="actions">';
  if (!S.submitted) {
    out += '<button class="btn btn-hint" data-action="hint">' + ICO.bulb + ' ' + (S.showHint?'Hide Hint':'AI Hint') + '</button>';
    out += '<button class="btn btn-skip" data-action="skip">' + ICO.skip + ' Skip</button>';
    out += '<button class="btn btn-sub' + (S.sel?' rdy':'') + '" data-action="submit"' + (!S.sel?' disabled':'') + '>' + ICO.send + ' Submit</button>';
  } else {
    out += '<button class="btn btn-next" data-action="next">' + ICO.arR + ' Next Question</button>';
  }
  out += '</div></div></div>';
  return out;
}

function renderResults(){
  const t = ct();
  const pct = Math.round(S.correct/total()*100);
  const R=80,sw=12,nr=R-sw/2,circ=nr*2*Math.PI,offset=circ-(pct/100)*circ;
  let gradeClass, gradeLabel, gradeIcon;
  if(pct>=80){gradeClass='grade-d';gradeLabel='Distinction';gradeIcon=ICO.trophy;}
  else if(pct>=60){gradeClass='grade-p';gradeLabel='Pass';gradeIcon=ICO.tgt;}
  else{gradeClass='grade-r';gradeLabel='Needs Review';gradeIcon=ICO.alt;}

  let out = '<div class="results"><div class="res-card">';
  out += '<h2 class="res-title">Topic Complete</h2>';
  out += '<p class="res-sub">' + t.t + '</p>';
  out += '<div class="ring-wrap">';
  out += '<svg width="200" height="200" style="transform:rotate(-90deg)">';
  out += '<circle stroke="#e5e7eb" fill="transparent" stroke-width="' + sw + '" r="' + nr + '" cx="100" cy="100"/>';
  out += '<circle stroke="#085041" fill="transparent" stroke-width="' + sw + '" stroke-dasharray="' + circ + ' ' + circ + '" style="stroke-dashoffset:' + offset + ';transition:stroke-dashoffset .6s ease" stroke-linecap="round" r="' + nr + '" cx="100" cy="100"/>';
  out += '<text x="100" y="92" text-anchor="middle" dominant-baseline="middle" style="transform:rotate(90deg);transform-origin:100px 100px;font-family:DM Sans,sans-serif;font-size:30px;font-weight:700;fill:#1F2937">' + pct + '%</text>';
  out += '<text x="100" y="115" text-anchor="middle" dominant-baseline="middle" style="transform:rotate(90deg);transform-origin:100px 100px;font-family:DM Sans,sans-serif;font-size:12px;fill:#6B7280">Score</text>';
  out += '</svg></div>';
  out += '<div class="grade ' + gradeClass + '">' + gradeIcon + ' ' + gradeLabel + '</div>';
  out += '<div class="res-stats">';
  out += '<div class="rs rs-ok"><span class="rs-v">' + S.correct + '</span><span class="rs-l">Correct</span></div>';
  out += '<div class="rs rs-ng"><span class="rs-v">' + S.wrong + '</span><span class="rs-l">Wrong</span></div>';
  out += '<div class="rs rs-sk"><span class="rs-v">' + S.skipped + '</span><span class="rs-l">Skipped</span></div>';
  out += '</div>';
  out += '<div class="res-acts">';
  out += '<button class="btn-restart" data-action="reset">' + ICO.rot + ' Retake</button>';
  out += '<button class="btn-home-r" data-action="home">' + ICO.home + ' Dashboard</button>';
  out += '</div></div></div>';
  return out;
}

function attachEvents(){
  document.addEventListener('click', handleClick, {once:true});
}
function handleClick(e){
  const btn = e.target.closest('[data-action],[data-topic],[data-answer],[data-goto],[data-group]');
  if (!btn){attachEvents();return;}
  const {action,topic,answer,group} = btn.dataset;
  const gt = btn.dataset.goto;
  if (topic){selectTopic(topic);return;}
  if (answer){selectAnswer(answer);render();return;}
  if (gt!==undefined){goToQ(parseInt(gt));return;}
  if (group){S.exGrps[group]=S.exGrps[group]===false?true:false;render();return;}
  if (action==='home'){goHome();return;}
  if (action==='toggleSB'){S.sbCol=!S.sbCol;render();return;}
  if (action==='hint'){toggleHint();return;}
  if (action==='skip'){skipQuestion();return;}
  if (action==='submit'){submitAnswer();return;}
  if (action==='next'){nextQuestion();return;}
  if (action==='reset'){resetTopic(S.tid);return;}
  attachEvents();
}

S.scores = loadScores();
for (const g of GROUPS) S.exGrps[g.label] = true;

loadData().then(data=>{
  topics=data;
  tmap={};
  for(const t of topics) tmap[t.id]=t;
  render();
}).catch(err=>{
  document.getElementById('app').innerHTML='<div class="loading"><p style="color:red">Failed to load data. Please refresh.</p></div>';
  console.error(err);
});
</script>
</body>
</html>
