<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Davidson's Clinical Self-Assessment</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Serif+Display:ital@1&display=swap" rel="stylesheet">
<style>
:root{--teal-dark:#085041;--teal:#0F6E56;--teal-light:#1D9E75;--teal-bg:#E1F5EE;--red:#A32D2D;--red-bg:#FCEBEB;--purple:#534AB7;--purple-bg:#F0EEFF;--amber-bg:#FAEEDA;--amber:#633806;--white:#fff;--g50:#F9FAFB;--g100:#F3F4F6;--g200:#E5E7EB;--g300:#D1D5DB;--g400:#9CA3AF;--g500:#6B7280;--g600:#4B5563;--g700:#374151;--g800:#1F2937}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'DM Sans',sans-serif;color:var(--g800);background:var(--g50);-webkit-font-smoothing:antialiased}
button{font-family:'DM Sans',sans-serif;cursor:pointer;border:none;background:none}
::-webkit-scrollbar{width:5px}::-webkit-scrollbar-thumb{background:var(--g300);border-radius:3px}
.app{display:flex;min-height:100vh}
/* SIDEBAR */
.sb{position:fixed;left:0;top:0;bottom:0;width:260px;background:var(--white);border-right:1px solid var(--g200);display:flex;flex-direction:column;z-index:100;overflow-y:auto;transition:width .3s}
.sb.col{width:54px}
.sb.col~.main{margin-left:54px}
.main{margin-left:260px;min-height:100vh;transition:margin-left .3s}
.sb-head{display:flex;align-items:center;justify-content:space-between;padding:14px;border-bottom:1px solid var(--g200);min-height:58px}
.sb-brand{display:flex;align-items:center;gap:9px;cursor:pointer;color:var(--teal-dark)}
.sb-brand-t{font-family:'DM Serif Display',serif;font-style:italic;font-size:14px;font-weight:700}
.sb-brand-s{font-size:10px;color:var(--g500);font-weight:500}
.sb-toggle{width:26px;height:26px;background:var(--g100);border-radius:6px;display:flex;align-items:center;justify-content:center;color:var(--g600);transition:all .2s;flex-shrink:0}
.sb-toggle:hover{background:var(--g200)}
.sb-nav{flex:1;padding:8px;overflow-y:auto}
.sb-home{width:100%;display:flex;align-items:center;gap:9px;padding:9px 11px;border-radius:8px;font-size:13px;font-weight:500;color:var(--g600);transition:all .2s;margin-bottom:4px}
.sb-home:hover,.sb-home.act{background:var(--teal-bg);color:var(--teal-dark)}
.sb-grp-btn{width:100%;display:flex;align-items:center;gap:7px;padding:7px 11px;font-size:11px;font-weight:600;color:var(--g400);text-transform:uppercase;letter-spacing:.5px;border-radius:6px;transition:all .2s}
.sb-grp-btn:hover{background:var(--g100)}
.sb-grp-btn .arr{margin-left:auto;transition:transform .2s;display:inline-block}
.sb-grp-btn.open .arr{transform:rotate(90deg)}
.sb-items{padding-left:4px;overflow:hidden;max-height:0;transition:max-height .3s ease}
.sb-items.open{max-height:600px}
.sb-topic{width:100%;display:flex;align-items:center;gap:7px;padding:7px 11px 7px 28px;border-radius:6px;font-size:12px;color:var(--g600);transition:all .2s;text-align:left}
.sb-topic:hover{background:var(--g100);color:var(--g800)}
.sb-topic.act{background:var(--teal-bg);color:var(--teal-dark);font-weight:500}
.sb-tn{flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.sb-tp{font-size:10px;font-weight:500;color:var(--teal)}
.sb-dot{width:7px;height:7px;background:var(--teal-light);border-radius:50%;flex-shrink:0}
.sb-col-nav{display:flex;flex-direction:column;align-items:center;gap:3px;padding-top:8px}
.sb-icon{width:38px;height:38px;display:flex;align-items:center;justify-content:center;border-radius:7px;color:var(--g600);transition:all .2s}
.sb-icon:hover,.sb-icon.act{background:var(--teal-bg);color:var(--teal-dark)}
/* HOME */
.home{padding:24px;max-width:1080px;margin:0 auto}
.hero{position:relative;background:var(--teal-dark);border-radius:20px;padding:36px 40px;margin-bottom:24px;overflow:hidden}
.hero-bg{position:absolute;inset:0;overflow:hidden;pointer-events:none}
.hero-c{position:absolute;border-radius:50%;border:1px solid rgba(255,255,255,.08)}
.hc1{width:300px;height:300px;top:-100px;right:-60px}
.hc2{width:200px;height:200px;bottom:-60px;right:120px;opacity:.5}
.hc-content{position:relative;color:#fff}
.hc-content h1{font-family:'DM Serif Display',serif;font-style:italic;font-size:28px;margin:10px 0 6px}
.hc-content p{font-size:14px;color:rgba(255,255,255,.75)}
.stats{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:28px}
.stat{background:var(--white);border-radius:13px;padding:18px;text-align:center;border:1px solid var(--g200);display:flex;flex-direction:column;align-items:center;gap:5px}
.stat-v{font-size:26px;font-weight:700}
.stat-l{font-size:12px;color:var(--g500);font-weight:500}
.grps{display:flex;flex-direction:column;gap:20px}
.grp-card{background:var(--white);border-radius:15px;padding:22px;border:1px solid var(--g200)}
.grp-hdr{font-size:14px;font-weight:600;color:var(--g700);margin-bottom:14px;padding-left:10px;border-left:3px solid}
.t-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(210px,1fr));gap:9px}
.t-card{display:flex;flex-direction:column;gap:7px;padding:14px;border-radius:11px;border:1.5px solid var(--g200);cursor:pointer;transition:all .2s;text-align:left;width:100%;background:var(--white)}
.t-card:hover{border-color:var(--teal);box-shadow:0 2px 8px rgba(8,80,65,.08)}
.t-card.done{border-color:var(--teal-light);background:var(--teal-bg)}
.t-hdr{display:flex;align-items:center;justify-content:space-between}
.t-title{font-size:13px;font-weight:600;color:var(--g800)}
.t-meta{display:flex;justify-content:space-between;font-size:11px;color:var(--g500)}
.t-score{font-weight:500;color:var(--teal)}
.t-bar{height:3px;background:var(--g200);border-radius:2px;overflow:hidden}
.t-fill{height:100%;border-radius:2px;transition:width .4s}
/* QUIZ */
.qz{max-width:860px;margin:0 auto;padding:22px}
.qz-hdr{background:var(--teal-dark);border-radius:15px;padding:20px;margin-bottom:16px;overflow:hidden}
.qz-hdr-inner{display:flex;align-items:center;gap:12px}
.qz-btn{width:34px;height:34px;background:rgba(255,255,255,.12);border-radius:7px;display:flex;align-items:center;justify-content:center;color:#fff;transition:all .2s;flex-shrink:0}
.qz-btn:hover{background:rgba(255,255,255,.22)}
.qz-title{font-size:17px;font-weight:700;color:#fff;flex:1}
.qz-sub{font-size:12px;color:rgba(255,255,255,.7)}
.score-bar{display:flex;gap:10px;margin-bottom:12px;flex-wrap:wrap}
.chip{display:flex;align-items:center;gap:7px;padding:9px 16px;border-radius:9px;font-size:13px;font-weight:500}
.chip-v{font-weight:700;font-size:15px}
.chip-ok{background:var(--teal-bg);color:var(--teal-dark)}
.chip-ng{background:var(--red-bg);color:var(--red)}
.chip-rm{background:#EDE9FE;color:var(--purple)}
.prog{height:3px;background:var(--g200);border-radius:2px;margin-bottom:14px;overflow:hidden}
.prog-f{height:100%;background:var(--teal-dark);border-radius:2px;transition:width .4s}
.q-nav{display:flex;gap:5px;flex-wrap:wrap;margin-bottom:16px;padding:10px;background:var(--white);border-radius:9px;border:1px solid var(--g200)}
.nd{width:26px;height:26px;border-radius:5px;border:1.5px solid var(--g300);background:var(--white);font-size:10px;font-weight:500;color:var(--g500);transition:all .2s}
.nd:hover{border-color:var(--teal);color:var(--teal)}
.nd.act{background:var(--teal-dark);border-color:var(--teal-dark);color:#fff}
.nd.ans{background:var(--teal-bg);border-color:var(--teal-light);color:var(--teal-dark)}
.nd.wrg{background:var(--red-bg);border-color:var(--red);color:var(--red)}
.q-card{background:var(--white);border-radius:15px;padding:26px;border:1px solid var(--g200)}
.q-text{font-family:'DM Serif Display',serif;font-style:italic;font-size:17px;line-height:1.75;color:var(--g800);margin-bottom:22px}
.opts{display:flex;flex-direction:column;gap:9px;margin-bottom:20px}
.opt{display:flex;align-items:flex-start;gap:12px;padding:13px 15px;border:1.5px solid var(--g200);border-radius:11px;background:var(--white);transition:all .2s;text-align:left;width:100%}
.opt:hover:not([disabled]){border-color:var(--purple);background:var(--purple-bg)}
.opt.sel{border-color:var(--purple);background:var(--purple-bg)}
.opt.ok{border-color:var(--teal);background:var(--teal-bg)}
.opt.ng{border-color:var(--red);background:var(--red-bg)}
.opt[disabled]{opacity:.55;cursor:default}
.ob{width:30px;height:30px;border-radius:7px;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:13px;flex-shrink:0;border:1.5px solid}
.ob-d{background:var(--g100);color:var(--g600);border-color:var(--g300)}
.ob-s{background:var(--purple);color:#fff;border-color:var(--purple)}
.ob-ok{background:var(--teal);color:#fff;border-color:var(--teal)}
.ob-ng{background:var(--red);color:#fff;border-color:var(--red)}
.ot{font-size:13px;line-height:1.5;color:var(--g700);padding-top:5px}
/* HINT */
.hint-box{display:flex;align-items:flex-start;gap:11px;padding:14px;background:var(--amber-bg);border-radius:11px;margin-bottom:16px;border:1px solid #F5D9A8;animation:fadeIn .3s ease}
.hint-ico{width:30px;height:30px;border-radius:50%;background:#F5D9A8;display:flex;align-items:center;justify-content:center;color:var(--amber);flex-shrink:0;font-size:14px}
.hint-txt{font-style:italic;font-size:13px;line-height:1.65;color:var(--amber);padding-top:4px}
.dots span{display:inline-block;width:5px;height:5px;background:var(--amber);border-radius:50%;animation:bounce 1.2s infinite;margin:0 1px}
.dots span:nth-child(2){animation-delay:.2s}
.dots span:nth-child(3){animation-delay:.4s}
@keyframes bounce{0%,80%,100%{transform:translateY(0)}40%{transform:translateY(-6px)}}
/* EXPLANATION */
.exp{padding:16px;border-radius:0 11px 11px 0;margin-bottom:16px;animation:fadeIn .3s ease}
.exp.ok{background:var(--teal-bg);border-left:4px solid var(--teal-light)}
.exp.ng{background:var(--red-bg);border-left:4px solid var(--red)}
.exp-hdr{display:flex;align-items:center;gap:7px;margin-bottom:8px}
.exp-ico{width:22px;height:22px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;flex-shrink:0}
.exp-ico.ok{background:var(--teal);color:#fff}
.exp-ico.ng{background:var(--red);color:#fff}
.exp-title{font-weight:600;font-size:13px}
.exp.ok .exp-title{color:var(--teal-dark)}
.exp.ng .exp-title{color:var(--red)}
.exp-clbl{margin-left:auto;font-size:12px;font-weight:500;color:var(--teal);background:rgba(29,158,117,.15);padding:3px 9px;border-radius:5px}
.exp-txt{font-size:13px;line-height:1.7;color:var(--g700)}
/* ACTIONS */
.actions{display:flex;gap:9px;flex-wrap:wrap}
.btn{display:flex;align-items:center;gap:7px;padding:11px 18px;border-radius:9px;font-size:13px;font-weight:500;transition:all .2s}
.btn-hint{background:var(--amber-bg);color:var(--amber);border:1px solid #F5D9A8}
.btn-hint:hover{background:#F5D9A8}
.btn-skip{background:var(--g100);color:var(--g600);border:1px solid var(--g200)}
.btn-skip:hover{background:var(--g200)}
.btn-sub{background:var(--g300);color:var(--g500);cursor:not-allowed;margin-left:auto}
.btn-sub.rdy{background:var(--teal-dark);color:#fff;cursor:pointer}
.btn-sub.rdy:hover{background:var(--teal)}
.btn-next{background:var(--teal-dark);color:#fff;margin-left:auto}
.btn-next:hover{background:var(--teal)}
/* RESULTS */
.results{display:flex;align-items:center;justify-content:center;min-height:100vh;padding:24px}
.res-card{background:var(--white);border-radius:20px;padding:38px;max-width:480px;width:100%;text-align:center;border:1px solid var(--g200);box-shadow:0 4px 20px rgba(0,0,0,.06)}
.res-title{font-size:22px;font-weight:700;margin-bottom:4px}
.res-sub{font-size:14px;color:var(--g500);margin-bottom:24px}
.ring-wrap{display:flex;justify-content:center;margin-bottom:20px}
.grade{display:inline-flex;align-items:center;gap:7px;padding:9px 22px;border-radius:100px;font-size:14px;font-weight:600;margin-bottom:20px}
.grade-d{background:var(--teal-bg);color:var(--teal-dark)}
.grade-p{background:#DBEAFE;color:#1E40AF}
.grade-r{background:var(--red-bg);color:var(--red)}
.res-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:24px}
.rs{padding:14px;border-radius:11px;text-align:center}
.rs-ok{background:var(--teal-bg)}
.rs-ng{background:var(--red-bg)}
.rs-sk{background:var(--g100)}
.rs-v{display:block;font-size:22px;font-weight:700;margin-bottom:3px}
.rs-ok .rs-v{color:var(--teal-dark)}
.rs-ng .rs-v{color:var(--red)}
.rs-sk .rs-v{color:var(--g600)}
.rs-l{font-size:12px;font-weight:500;color:var(--g500)}
.res-acts{display:flex;gap:9px}
.btn-restart{flex:1;display:flex;align-items:center;justify-content:center;gap:7px;padding:11px 18px;border-radius:9px;font-size:13px;font-weight:500;background:var(--teal-dark);color:#fff;transition:all .2s}
.btn-restart:hover{background:var(--teal)}
.btn-home-r{flex:1;display:flex;align-items:center;justify-content:center;gap:7px;padding:11px 18px;border-radius:9px;font-size:13px;font-weight:500;background:var(--g100);color:var(--g700);border:1px solid var(--g200);transition:all .2s}
.btn-home-r:hover{background:var(--g200)}
/* LOADING */
.loading{display:flex;flex-direction:column;align-items:center;justify-content:center;height:100vh;gap:14px}
.spinner{width:38px;height:38px;border:3px solid var(--g200);border-top-color:var(--teal-dark);border-radius:50%;animation:spin .8s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
@keyframes fadeIn{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:translateY(0)}}
@media(max-width:768px){
  .sb{transform:translateX(-100%)}
  .main{margin-left:0!important}
  .stats{grid-template-columns:repeat(2,1fr)}
  .qz{padding:12px}
  .q-card{padding:16px}
}
</style>
</head>
<body>
<div id="app"><div class="loading"><div class="spinner"></div><p style="font-size:14px;color:#6B7280">Loading assessment data…</p></div></div>
<script>
const BDATA = "";

async function loadData() {
  const b = atob(BDATA);
  const bytes = new Uint8Array(b.length);
  for (let i = 0; i < b.length; i++) bytes[i] = b.charCodeAt(i);
  const ds = new DecompressionStream('gzip');
  const writer = ds.writable.getWriter();
  writer.write(bytes); writer.close();
  const chunks = [];
  const reader = ds.readable.getReader();
  while (true) { const {done,value} = await reader.read(); if (done) break; chunks.push(value); }
  const total = chunks.reduce((s,c)=>s+c.length,0);
  const flat = new Uint8Array(total);
  let off = 0;
  for (const c of chunks) { flat.set(c,off); off+=c.length; }
  return JSON.parse(new TextDecoder().decode(flat));
}

const SKEY = 'davidson_v3';
let topics = [], tmap = {};
let S = {
  view:'home', tid:null, qi:0, sel:null, submitted:false,
  showHint:false, hintText:null, hintLoading:false,
  correct:0, wrong:0, skipped:0,
  answered:new Set(), wrongSet:new Set(),
  scores:{}, exGrps:{}, sbCol:false
};

function loadScores(){try{const s=localStorage.getItem(SKEY);return s?JSON.parse(s):{};}catch{return {};}}
function saveScores(){try{localStorage.setItem(SKEY,JSON.stringify(S.scores));}catch{}}

const hintCache = {};
async function generateHint(q) {
  if (hintCache[q.i]) return hintCache[q.i];
  const optLines = q.ok.map((k,i) => k+'. '+q.ov[i]).join('\n');
  const prompt = 'You are a medical educator writing a clinical reasoning hint for a Davidson\'s exam question.\n\nQuestion: '+q.q+'\n\nOptions:\n'+optLines+'\n\nWrite a SINGLE concise hint (2-3 sentences) that:\n1. Points to the pathophysiology or mechanism — NOT the answer directly\n2. Uses precise medical terminology (receptor types, biochemical pathways, diagnostic criteria)\n3. Highlights the distinguishing feature between the options\n\nDo NOT reveal which option is correct. Be scientific and specific.\nReturn ONLY the hint text, no preamble.';
  const resp = await fetch('https://api.anthropic.com/v1/messages',{
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:150,messages:[{role:'user',content:prompt}]})
  });
  const data = await resp.json();
  const hint = (data.content&&data.content[0]&&data.content[0].text) ? data.content[0].text.trim() : 'Focus on the pathophysiology and distinguishing clinical features for each option.';
  hintCache[q.i] = hint;
  return hint;
}

function ct(){return tmap[S.tid]||null;}
function cq(){const t=ct();return t?t.qs[S.qi]:null;}
function total(){const t=ct();return t?t.qs.length:0;}
function remaining(){return total()-S.answered.size;}
function isDone(){return total()>0&&S.answered.size>=total();}

function selectTopic(id){
  S={...S,view:'quiz',tid:id,qi:0,sel:null,submitted:false,showHint:false,hintText:null,hintLoading:false,correct:0,wrong:0,skipped:0,answered:new Set(),wrongSet:new Set()};
  render();
}
function selectAnswer(a){if(S.submitted)return;S.sel=a;render();}
function submitAnswer(){
  if(!S.sel||S.submitted)return;
  const q=cq(); const ok=S.sel===q.a;
  const ans=new Set(S.answered); ans.add(S.qi);
  const ws=new Set(S.wrongSet); if(!ok)ws.add(S.qi);
  S={...S,submitted:true,correct:ok?S.correct+1:S.correct,wrong:ok?S.wrong:S.wrong+1,answered:ans,wrongSet:ws};
  if(isDone())finishTopic();
  render();
}
function skipQuestion(){
  const ans=new Set(S.answered); ans.add(S.qi);
  const last=S.qi>=total()-1;
  S={...S,skipped:S.skipped+1,answered:ans};
  if(last){finishTopic();}else{S={...S,qi:S.qi+1,sel:null,submitted:false,showHint:false,hintText:null};}
  render();
}
function nextQuestion(){
  const ans=new Set(S.answered); ans.add(S.qi);
  const last=S.qi>=total()-1;
  S={...S,answered:ans};
  if(last){finishTopic();}else{S={...S,qi:S.qi+1,sel:null,submitted:false,showHint:false,hintText:null};}
  render();
}
function goToQ(i){if(S.answered.has(i))return;S={...S,qi:i,sel:null,submitted:false,showHint:false,hintText:null};render();}
function finishTopic(){
  const t=ct();
  S.scores[S.tid]={tid:S.tid,title:t.t,total:t.qs.length,correct:S.correct,wrong:S.wrong,skipped:S.skipped,done:true};
  saveScores();
}
function goHome(){S={...S,view:'home',tid:null};render();}
function resetTopic(id){delete S.scores[id];saveScores();selectTopic(id);}

async function toggleHint(){
  if(S.showHint){S.showHint=false;render();return;}
  S.showHint=true;
  if(!S.hintText){
    S.hintLoading=true;render();
    try{S.hintText=await generateHint(cq());}
    catch(e){S.hintText='Consider the key pathophysiological mechanism and the distinguishing clinical features for each option.';}
    S.hintLoading=false;
  }
  render();
}

const GROUPS = [
  {label:'Emergency & Environment',ids:['poisoning','envenomation','environmental','acute_critical'],color:'#085041'},
  {label:'Infectious Disease',ids:['principles_id','general_id','hiv_aids','stis'],color:'#534AB7'},
  {label:'Systemic Medicine',ids:['cardiology','respiratory','gastroenterology','hepatology','nephrology','neurology','stroke','haematology'],color:'#0F6E56'},
  {label:'Metabolic & Endocrine',ids:['biochemistry','endocrinology','diabetes','nutrition'],color:'#A32D2D'},
  {label:'Specialties',ids:['rheumatology','psychiatry','dermatology'],color:'#633806'},
];

// ── SVG helpers (no template literals needed) ──
function svgPath(d,extra){return '<svg width="'+(extra||'16')+'" height="'+(extra||'16')+'" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">'+d+'</svg>';}
const ICO = {
  home: svgPath('<path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>'),
  steth: svgPath('<path d="M4.8 2.3A.3.3 0 1 0 5 2H4a2 2 0 0 0-2 2v5a6 6 0 0 0 6 6 6 6 0 0 0 6-6V4a2 2 0 0 0-2-2h-1a.2.2 0 1 0 .3.3"/><path d="M8 15v1a6 6 0 0 0 6 6 6 6 0 0 0 6-6v-4"/><circle cx="20" cy="10" r="2"/>'),
  trophy: svgPath('<path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/>'),
  trend: svgPath('<polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/>','18'),
